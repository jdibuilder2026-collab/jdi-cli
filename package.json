{
  "name": "jdi-cli",
  "version": "0.2.0",
  "description": "JDI — Claude Code를 내장한 AI 코딩 에이전트. 로그인 한 번으로 바로 사용.",
  "type": "module",
  "bin": {
    "jdi": "./dist/bin/jdi.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/jdi.js",
    "lint": "tsc --noEmit"
  },
  "keywords": ["cli", "ai", "coding-agent", "claude", "claude-code"],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
